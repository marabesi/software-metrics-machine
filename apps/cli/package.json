{
  "name": "@smmachine/cli",
  "version": "0.0.5",
  "private": false,
  "type": "commonjs",
  "description": "Software Metrics Machine - CLI",
  "main": "dist/index.cjs",
  "bin": {
    "smm": "dist/index.cjs"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:deps": "pnpm --filter @smmachine/utils build && pnpm --filter @smmachine/core build",
    "dev": "tsx src/index.ts",
    "prepack": "pnpm run build:deps && pnpm run build",
    "test": "vitest --watch=false",
    "test:ci": "vitest run ./__tests__",
    "clean": "rm -rf dist",
    "lint": "eslint ."
  },
  "dependencies": {
    "commander": "catalog:"
  },
  "devDependencies": {
    "@smmachine/core": "workspace:*",
    "@smmachine/utils": "workspace:*",
    "@smmachine/rest": "workspace:*",
    "@smmachine/webapp": "workspace:*",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "tsx": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
