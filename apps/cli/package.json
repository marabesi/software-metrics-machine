{
  "name": "@smmachine/cli",
  "version": "0.0.5",
  "private": false,
  "type": "module",
  "description": "Software Metrics Machine - CLI",
  "main": "dist/index.js",
  "bin": {
    "smm": "dist/index.js"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:deps": "pnpm --filter @smmachine/utils build && pnpm --filter @smmachine/core build",
    "dev": "tsx src/index.ts",
    "prepack": "pnpm run build:deps && pnpm run build",
    "test": "vitest",
    "test:ci": "vitest run ./__tests__"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@smmachine/core": "workspace:*",
    "@smmachine/utils": "workspace:*",
    "@types/node": "*",
    "ts-node": "*",
    "tsconfig-paths": "*",
    "tsx": "*",
    "tsup": "^8.5.0",
    "typescript": "*",
    "vitest": "*"
  }
}
