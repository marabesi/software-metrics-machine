{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "node16",
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "node16",
    "allowSyntheticDefaultImports": true,
    "baseUrl": "../..",
    "paths": {
      "@smmachine/utils": ["packages/utils/src/*"],
      "@smmachine/core": ["packages/core/src/*"]
    }
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "__tests__"]
}
