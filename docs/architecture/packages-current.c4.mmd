C4Container
title Software Metrics Machine - Current Package Architecture

Person(developer, "Developer", "Runs local analysis and explores metrics")

System_Ext(codeHosts, "Code Hosting / PM Systems", "GitHub, GitLab, Jira, SonarQube and related APIs")

System_Boundary(smm, "software-metrics-machine monorepo") {
  Container(cli, "@smmachine/cli", "TypeScript (CommonJS)", "Command-line entrypoint for metric collection and orchestration")
  Container(webapp, "@smmachine/webapp", "Next.js + React", "Dashboard UI for software metrics")
  Container(rest, "@smmachine/rest", "NestJS", "REST API exposing metrics and configuration endpoints")
  Container(core, "@smmachine/core", "TypeScript library", "Domain logic, providers, orchestration and metric computation")
  Container(utils, "@smmachine/utils", "TypeScript library", "Shared helpers such as logging and utility functions")
}

Rel(developer, cli, "Runs analysis commands", "CLI")
Rel(developer, webapp, "Uses dashboard", "Browser")
Rel(webapp, rest, "Reads metrics and configuration", "HTTP/JSON")

Rel(cli, core, "Invokes domain services", "workspace package")
Rel(cli, utils, "Uses logging/utilities", "workspace package")
Rel(rest, core, "Uses domain services", "workspace package")
Rel(rest, utils, "Uses logging/utilities", "workspace package")
Rel(core, utils, "Uses shared utilities", "workspace package")

Rel(core, codeHosts, "Fetches repository/project data", "HTTPS APIs")