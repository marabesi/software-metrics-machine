{
  "name": "@smm/utils",
  "version": "0.0.1",
  "private": true,
  "description": "Software Metrics Machine - Utility functions",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --outDir dist",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "utilities",
    "helpers"
  ],
  "author": "Marabesi",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "*",
    "typescript": "*",
    "vitest": "*"
  },
  "dependencies": {
    "date-fns": "*"
  }
}
