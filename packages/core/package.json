{
  "name": "@smmachine/core",
  "private": true,
  "version": "0.0.1",
  "description": "Software Metrics Machine - Core business logic library",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --outDir dist",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "metrics",
    "dora",
    "business-logic"
  ],
  "author": "Marabesi",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "axios": "catalog:",
    "date-fns": "catalog:",
    "@smmachine/utils": "workspace:*"
  }
}
