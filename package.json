{
  "name": "software-metrics-machine",
  "version": "0.4.0",
  "description": "Data-driven approach to software measurement for high-performing teams",
  "type": "module",
  "author": "Marabesi",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run -r build",
    "dev": "concurrently \"pnpm --filter=webapp run dev --port=3000\" \"PORT=8000 pnpm --filter=rest run dev\"",
    "build:packages": "cd ./packages/utils && npm run build && cd ../core && npm run build",
    "test": "pnpm -r run test",
    "typecheck": "npm run typecheck:packages",
    "typecheck:packages": "cd ./packages/core && npm run type-check",
    "cli": "cd ./apps/cli && pnpm run dev"
  },
  "keywords": [
    "software-metrics",
    "dora",
    "deployment-frequency",
    "lead-time",
    "change-failure-rate",
    "mean-time-recovery"
  ],
  "engines": {
    "node": ">=25.2.1",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@vitest/coverage-v8": "^4.1.2",
    "axios": "^1.14.0",
    "chalk": "^5.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "inquirer": "^13.3.2",
    "ora": "^9.3.0",
    "reflect-metadata": "^0.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
