{
  "name": "@smmachine/launcher",
  "version": "0.3.0",
  "description": "Data-driven approach to software measurement for high-performing teams",
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "smm": "dist/index.cjs"
  },
  "repository": {
    "url": "https://github.com/marabesi/software-metrics-machine"
  },
  "files": [
    "dist",
    "apps/webapp/.next",
    "apps/webapp/public",
    "README.md",
    "LICENSE"
  ],
  "author": "Marabesi",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run -r build",
    "clean": "pnpm run -r clean",
    "lint": "pnpm run -r lint",
    "clean:full": "rm -rf node_modules && (cd apps/cli && rm -rf node_modules) && (cd apps/rest && rm -rf node_modules) && (cd apps/webapp && rm -rf node_modules) && (cd packages/core && rm -rf node_modules) && (cd packages/utils && rm -rf node_modules)",
    "build:npm": "pnpm run -r clean && pnpm --filter @smmachine/utils build && pnpm --filter @smmachine/core build && pnpm --filter @smmachine/rest build && pnpm --filter @smmachine/webapp build && pnpm exec tsup",
    "dev": "concurrently \"pnpm --filter=webapp run dev --port=3000\" \"PORT=8000 pnpm --filter=rest run dev\"",
    "build:packages": "cd ./packages/utils && npm run build && cd ../core && npm run build",
    "test": "pnpm -r run test",
    "typecheck": "npm run typecheck:packages",
    "typecheck:packages": "cd ./packages/core && npm run type-check",
    "cli": "cd ./apps/cli && pnpm run dev",
    "prepack": "pnpm run build:npm"
  },
  "keywords": [
    "software-metrics",
    "dora",
    "deployment-frequency",
    "lead-time",
    "change-failure-rate",
    "mean-time-recovery"
  ],
  "engines": {
    "node": ">=25.2.1",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@emotion/cache": "catalog:",
    "@emotion/react": "catalog:",
    "@emotion/styled": "catalog:",
    "@fontsource/roboto": "catalog:",
    "@mui/icons-material": "catalog:",
    "@mui/material": "catalog:",
    "@mui/material-nextjs": "catalog:",
    "@mui/x-date-pickers": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "date-fns": "catalog:",
    "dayjs": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "recharts": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "swagger-ui-express": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "axios": "catalog:",
    "chalk": "catalog:",
    "concurrently": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "inquirer": "catalog:",
    "ora": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
