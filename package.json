{
  "name": "@smmachine/launcher",
  "version": "0.5.21",
  "description": "Data-driven approach to software measurement for high-performing teams",
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "smm": "dist/index.cjs"
  },
  "repository": {
    "url": "https://github.com/marabesi/software-metrics-machine"
  },
  "files": [
    "dist",
    "apps/cli/fetch-codemaat.sh",
    "apps/cli/tools",
    "apps/webapp/.next",
    "apps/webapp/public",
    "README.md",
    "LICENSE"
  ],
  "author": "Marabesi",
  "license": "MIT",
  "scripts": {
    "build:local": "pnpm run build; pnpm run lint -- --fix",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "watch": "turbo run watch",
    "docs": "cd docs/vitepress && pnpm run docs:dev",
    "clean:full": "rm -rf node_modules && (cd apps/cli && rm -rf node_modules) && (cd apps/rest && rm -rf node_modules) && (cd apps/webapp && rm -rf node_modules) && (cd packages/core && rm -rf node_modules) && (cd packages/utils && rm -rf node_modules)",
    "build:npm": "turbo run clean && pnpm --filter @smmachine/utils build && pnpm --filter @smmachine/core build && pnpm --filter @smmachine/rest build && pnpm --filter @smmachine/webapp build && pnpm exec tsup",
    "dev": "turbo run dev --filter=./apps/*",
    "build:packages": "turbo run build --filter=@smmachine/utils --filter=@smmachine/core",
    "test": "turbo run test",
    "typecheck": "turbo run type-check",
    "cli": "cd ./apps/cli && pnpm run dev",
    "prepack": "pnpm run build:npm"
  },
  "keywords": [
    "software-metrics",
    "dora",
    "deployment-frequency",
    "lead-time",
    "change-failure-rate",
    "mean-time-recovery"
  ],
  "engines": {
    "node": ">=25.2.1",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.34.1",
  "dependencies": {
    "@emotion/cache": "catalog:",
    "@emotion/react": "catalog:",
    "@emotion/styled": "catalog:",
    "@fontsource/roboto": "catalog:",
    "@mui/icons-material": "catalog:",
    "@mui/material": "catalog:",
    "@mui/material-nextjs": "catalog:",
    "@mui/x-date-pickers": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/swagger": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "date-fns": "catalog:",
    "dayjs": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "recharts": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "swagger-ui-express": "catalog:",
    "tailwind-merge": "catalog:",
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "axios": "catalog:",
    "chalk": "catalog:",
    "concurrently": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "inquirer": "catalog:",
    "ora": "catalog:",
    "ts-node": "catalog:",
    "tsconfig-paths": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
